{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ecommerce-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ]
  },
  "ConnectionStrings": {
    "sqlConnection": "Data Source=localhost;Initial Catalog=ECommerce;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Pooling=False;Connect Timeout=30;Encrypt=False;Trust Server Certificate=True;"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-must-be-at-least-32-characters-long!",
    "validIssuer": "AlchemistLowkey",
    "validAudience": "https://localhost:5001",
    "expires": 5
  },
  "PaymentProvider": "Flutterwave",
  "Paystack": {
    "SecretKey": "sk_test_YOUR_PAYSTACK_SECRET_KEY",
    "WebhookSecret": "YOUR_PAYSTACK_WEBHOOK_SECRET",
    "BaseUrl": "https://api.paystack.co"
  },
  "Flutterwave": {
    "SecretKey": "FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "WebhookSecret": "YOUR_FLUTTERWAVE_WEBHOOK_SECRET",
    "BaseUrl": "https://api.flutterwave.com/v3",
    "RedirectUrl": "https://your-frontend.example.com/payment-complete"
  },
  "AllowedHosts": "*"
}
